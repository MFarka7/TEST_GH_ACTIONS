  },
  "item": [
    {
      "name": "01_User_Creation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "",
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Check JSON structure\", function () {",
              "    pm.expect(jsonData.data.role).to.eql(\"user\");",
              "    pm.expect(jsonData.data).to.have.property(\"apiKey\");",
              "});",
              "",
              "pm.test(\"Success is true\", function () {",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "pm.collectionVariables.set(\"apiKey\", jsonData.data.apiKey);",
              "",
              "pm.test(\"Email in response matches email sent\", function () {",
              "    const sentEmail = pm.environment.get(\"currentEmail\");",
              "    pm.expect(jsonData.data.email).to.eql(sentEmail.toLowerCase());",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate and store the email before sending\r",
              "const email = pm.variables.replaceIn(\"{{$randomEmail}}\");\r",
              "pm.environment.set(\"currentEmail\", email);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\":\"{{$randomFullName}}\",\r\n    \"email\":\"{{currentEmail}}\",\r\n    \"password\":\"{{$randomPassword}}\"\r\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/user/create",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "user",
            "create"
          ]
        }
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
